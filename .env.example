# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/news_aggregator

# Scheduler
REFRESH_MINUTES=30
SCHEDULER_TICK_SECONDS=60
SCHEDULER_DRAIN_JOBS=false
SCHEDULER_MAX_JOBS=1

# Worker
WORKER_CONCURRENCY=1
WORKER_BATCH_SIZE=1

# AI (pick one, optional for now)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# LLM Scoring (recommended)
LLM_PROVIDER=openrouter
LLM_API_KEY=
LLM_MODEL=openai/gpt-4o-mini
SCORING_FALLBACK_MODEL=
